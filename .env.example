# ============================================================
# 环境变量配置模板
# 复制此文件为 .env 并填入实际值
# ============================================================

# ---------- 必填项 ----------

# PostgreSQL 数据库连接
# 格式: postgresql://用户名:密码@主机:端口/数据库名
DATABASE_URL="postgresql://fangame:your_password@localhost:5432/fangame"

# NextAuth 认证密钥（至少 32 位随机字符串）
# 生成方式: 终端运行 openssl rand -base64 32
NEXTAUTH_SECRET="替换为随机生成的密钥"

# 应用访问地址（部署后填公网 IP 或域名）
NEXTAUTH_URL="http://your_server_ip"

# ---------- 可选项 ----------

# Sentry 错误监控（不填则不启用）
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""

# Cloudflare R2 文件存储（不填则使用本地存储）
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_ACCESS_KEY_SECRET=""
R2_BUCKET_NAME=""
R2_PUBLIC_URL=""

# UploadThing 文件上传（不填则使用本地存储）
UPLOADTHING_TOKEN=""

# Resend 邮件服务（不填则不启用邮件功能）
RESEND_API_KEY=""