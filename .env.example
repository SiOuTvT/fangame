# Database
DATABASE_URL="postgresql://user:password@localhost:5432/fangame"

# NextAuth
NEXTAUTH_SECRET="generate-a-random-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Cloudflare R2 图片存储（S3 兼容）
# 在 Cloudflare Dashboard > R2 > 管理 R2 API 令牌 中创建
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_BUCKET_NAME="your-bucket-name"
# R2 公开访问 URL（在 R2 Bucket > 设置 > 公开访问 中启用，或绑定自定义域名）
# 格式：https://pub-xxxx.r2.dev  或  https://assets.yourdomain.com
R2_PUBLIC_URL="https://pub-xxxx.r2.dev"

# Sentry (错误监控 - 可选)
# SENTRY_DSN="https://xxx@sentry.io/xxx"
# SENTRY_AUTH_TOKEN="sntrys_xxx"

# VNDB API 代理（可选 - 中国大陆服务器直连 api.vndb.org 可能 ECONNREFUSED，需配置代理）
# 格式: http://user:password@host:port  或  socks5://host:port
# VNDB_API_PROXY="http://127.0.0.1:7890"

# Upstash Redis (缓存 - 可选，未配置时自动降级为内存缓存)
# UPSTASH_REDIS_REST_URL="https://xxx.upstash.io"
# UPSTASH_REDIS_REST_TOKEN="AXxx"
