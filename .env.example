# ═══════════════════════════════════════════
# Fangame 部署配置
# 复制此文件为 .env，无需修改即可启动
# docker compose up -d
# ═══════════════════════════════════════════

# ── 数据库连接 ──
# 默认使用 compose 内置 PostgreSQL，无需配置
# 如使用外部数据库，取消注释并填写：
# DATABASE_URL=postgresql://用户名:密码@主机:端口/数据库名
# DATABASE_URL=

# ── 应用密钥 ──
# 留空则首次启动自动生成（容器重建后用户需重新登录）
# 正式部署建议填写：openssl rand -base64 48
# NEXTAUTH_SECRET=

# ── 网站访问地址 ──
# 必须与用户实际访问地址完全一致（含协议）
# 留空默认 http://localhost:3000
# 正式部署请设置为实际域名，例如：https://fangame.example.com
# NEXTAUTH_URL=

# ═══════════════════════════════════════════
# 以下均为可选配置，不影响核心功能
# ═══════════════════════════════════════════

# ── Cloudflare R2 文件存储（可选，不填则使用本地存储）──
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
# R2_PUBLIC_URL=

# ── Upstash Redis 缓存（可选，不填则使用内存缓存）──
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# ── Resend 邮件服务（可选，用于密码重置）──
# RESEND_API_KEY=

# ── Sentry 错误监控（可选）──
# SENTRY_DSN=

# ── Turnstile 验证码（可选，用于注册防机器人）──
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# ── UploadThing 文件上传（可选）──
# UPLOADTHING_TOKEN=

# ═══════════════════════════════════════════
# 构建时变量（仅 Sentry sourcemap 上传需要，运行时无需设置）
# ═══════════════════════════════════════════
# SENTRY_ORG=
# SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN=
