generator client {
  provider      = "prisma-client-js"
  engineType    = "library"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
  SUPER_ADMIN
}

model User {
  id            String         @id @default(cuid())
  serialId      Int            @unique @default(autoincrement())
  uid           String         @unique @default("")
  username      String         @unique
  email         String         @unique
  password      String
  avatar        String         @default("")
  avatarFrameId String?
  composedAvatarUrl String?    @default("")
  banner        String         @default("")
  bio           String         @default("")
  role          UserRole       @default(USER)
  faveGameId    String?
  createdAt     DateTime       @default(now())
  avatarFrame   AvatarFrame?   @relation(fields: [avatarFrameId], references: [id], onDelete: SetNull)
  comments      Comment[]
  favorites     Favorite[]
  playStatuses  PlayStatus[]
  forumPosts    ForumPost[]
  forumComments ForumComment[]
  checkIns      CheckIn[]
  resetTokens   PasswordResetToken[]
  ratings       GameRating[]
  accounts      Account[]
  sessions      Session[]
  following     Follow[]        @relation("following")
  followers     Follow[]        @relation("followers")
  notifications Notification[]  @relation("notifications")
  sentNotifications Notification[] @relation("notificationTarget")
  collections      Collection[]
  publishedGames   Game[]
  gameResources    GameResource[]
  forumPostLikes   ForumPostLike[]
  forumCommentLikes ForumCommentLike[]
  commentLikes     CommentLike[]
  achievements     UserAchievement[]
  resourceReports  ResourceReport[]
  auditLogs        AuditLog[]

  @@index([role])
  @@index([avatarFrameId])
}

model AvatarFrame {
  id          String   @id @default(cuid())
  name        String
  description String   @default("")
  imageUrl    String
  isPublic    Boolean  @default(true)
  sort        Int      @default(0)
  createdAt   DateTime @default(now())
  users       User[]

  @@index([isPublic, sort])
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())
  follower    User     @relation("following", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("followers", fields: [followingId], references: [id], onDelete: Cascade)
  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
}

model Game {
  id            String       @id @default(cuid())
  serialId      Int          @unique @default(autoincrement())
  title         String
  originalWork  String       @default("")
  description   String       @default("")
  coverImage    String       @default("")
  screenshots   Json         @default("[]")
  downloadLinks Json         @default("[]")
  status        String       @default("完结")
  isNsfw        Boolean      @default(false)
  vndbId        String       @default("")
  viewCount     Int          @default(0)
  downloadCount Int          @default(0)
  favoriteCount Int          @default(0)
  isPublished   Boolean      @default(false)
  publishedAt   DateTime?
  reviewedBy    String?
  reviewedAt    DateTime?
  rejectReason  String       @default("")
  releaseDate   DateTime?
  gameDuration  String       @default("")
  studioName    String       @default("")
  englishName   String       @default("")
  aliases       String       @default("")
  publisherId   String?
  /// PostgreSQL 全文搜索向量
  searchVector  String       @default("") @db.Text
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  publisher     User?        @relation(fields: [publisherId], references: [id], onDelete: SetNull)
  tags          GameTag[]
  comments      Comment[]
  favorites     Favorite[]
  playStatuses  PlayStatus[]
  reports       GameReport[]
  ratings       GameRating[]
  creators      GameCreator[]
  resources     GameResource[]
  logs          GameLog[]

  @@index([isPublished, isNsfw, createdAt])
  @@index([isPublished, viewCount])
  @@index([isPublished, favoriteCount])
  @@index([title])
  @@index([vndbId])
  @@index([publisherId])
  @@index([searchVector])
}

model TagGroup {
  id          String   @id @default(cuid())
  name        String   @unique
  description String   @default("")
  color       String   @default("#7c8a9e")
  positions   String   @default("[]")  // JSON array of position keys
  isPreset    Boolean  @default(false)  // 系统内置组，不可删除
  tags        Tag[]
  createdAt   DateTime @default(now())
}

model Tag {
  id          String    @id @default(cuid())
  name        String    @unique
  description String    @default("")
  color       String    @default("#a78bfa")
  sortOrder   Int       @default(0)
  isVisible   Boolean   @default(true)
  groupId     String?
  createdAt   DateTime  @default(now())
  group       TagGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)
  games       GameTag[]
  @@index([groupId])
  @@index([sortOrder])
}

model GameTag {
  gameId String
  tagId  String
  game   Game   @relation(fields: [gameId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)
  @@id([gameId, tagId])
  @@index([tagId])
}

model Comment {
  id        String    @id @default(cuid())
  gameId    String
  userId    String
  content   String
  imageUrl  String    @default("")
  likeCount Int       @default(0)
  parentId  String?
  createdAt DateTime  @default(now())
  game      Game      @relation(fields: [gameId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent    Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: SetNull)
  replies   Comment[] @relation("CommentReplies")
  likes     CommentLike[]

  @@index([gameId, createdAt])
  @@index([userId])
  @@index([parentId])
}

model GameResource {
  id              String           @id @default(cuid())
  gameId          String
  userId          String
  resourceName    String           @default("")
  resourceNote    String           @default("")
  /// JSON 数组：平台标签 ["PC", "Android", ...]
  platform        Json             @default("[]")
  /// JSON 数组：语言标签 ["中文", "日文", ...]
  language        Json             @default("[]")
  /// JSON 数组：运行方式 ["ONS", "Kirikiri", ...]
  runType         Json             @default("[]")
  /// JSON 数组：资源内容 ["本体", "存档", ...]
  resourceContent Json             @default("[]")
  isReported      Boolean          @default(false)
  reportedAt      DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  game            Game             @relation(fields: [gameId], references: [id], onDelete: Cascade)
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  entries         GameResourceEntry[]
  reports         ResourceReport[]

  @@index([gameId])
  @@index([userId])
  @@index([createdAt])
}

model GameResourceEntry {
  id              String        @id @default(cuid())
  resourceId      String
  url             String
  extractCode     String        @default("")
  decompressCode  String        @default("")
  fileSize        String        @default("")
  resource        GameResource  @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@index([resourceId])
}

model ResourceReport {
  id         String       @id @default(cuid())
  resourceId String
  userId     String
  createdAt  DateTime     @default(now())
  resource   GameResource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([resourceId, userId])
  @@index([resourceId])
  @@index([userId])
}

model Favorite {
  id           String   @id @default(cuid())
  userId       String
  gameId       String
  collectionId String?
  createdAt    DateTime @default(now())
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  game         Game       @relation(fields: [gameId], references: [id], onDelete: Cascade)
  collection   Collection? @relation(fields: [collectionId], references: [id], onDelete: SetNull)
  @@unique([userId, gameId])
  @@index([collectionId])
}

model Collection {
  id          String     @id @default(cuid())
  userId      String
  name        String
  description String     @default("")
  isDefault   Boolean    @default(false)
  sortOrder   Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  favorites   Favorite[]

  @@unique([userId, name])
  @@index([userId])
}

model PlayStatus {
  id     String @id @default(cuid())
  userId String
  gameId String
  status String @default("想玩")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  game   Game   @relation(fields: [gameId], references: [id], onDelete: Cascade)
  @@unique([userId, gameId])
  @@index([gameId])
}

model GameReport {
  id        String   @id @default(cuid())
  gameId    String
  ip        String
  reason    String   @default("")
  createdAt DateTime @default(now())
  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  @@unique([gameId, ip])
}

model Announcement {
  id           String    @id @default(cuid())
  title        String
  content      String
  imageUrl     String    @default("")
  link         String    @default("")
  authorName   String    @default("")
  authorAvatar String    @default("")
  isActive     Boolean   @default(true)
  startAt      DateTime?
  endAt        DateTime?
  sortOrder    Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([sortOrder])
}

model Playlist {
  id        String   @id @default(cuid())
  name      String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  music     Music[]

  @@index([sortOrder])
}

model Music {
  id         String    @id @default(cuid())
  title      String
  filename   String
  url        String    @default("")
  isActive   Boolean   @default(true)
  playlistId String?
  createdAt  DateTime  @default(now())
  playlist   Playlist? @relation(fields: [playlistId], references: [id], onDelete: SetNull)

  @@index([playlistId])
}

model GameLog {
  id        String   @id @default(cuid())
  gameId    String
  content   String
  createdAt DateTime @default(now())
  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@index([gameId])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  target    String   @default("")
  detail    String   @default("")
  ip        String   @default("")
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

model Creator {
  id          String        @id @default(cuid())
  vndbId      String        @default("")
  name        String
  nameJa      String        @default("")
  avatar      String        @default("")
  bio         String        @default("")
  gender      String        @default("")
  twitterUrl  String        @default("")
  wikipediaUrl String       @default("")
  createdAt   DateTime      @default(now())
  games       GameCreator[]

  @@index([vndbId])
  @@index([name])
}

model GameCreator {
  id        String  @id @default(cuid())
  gameId    String
  creatorId String
  role      String  // scenario / art / chardesign / music / director / songs
  game      Game    @relation(fields: [gameId], references: [id], onDelete: Cascade)
  creator   Creator @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  @@unique([gameId, creatorId, role])
  @@index([gameId])
  @@index([creatorId])
}

model GameRating {
  id        String    @id @default(cuid())
  gameId    String
  userId    String
  score     Int       @db.SmallInt // 1-5，应用层验证
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  game      Game      @relation(fields: [gameId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([gameId, userId])
  @@index([gameId])
  @@index([userId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model CheckIn {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime @db.Date
  marks     Int      @default(0)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([userId, date])
  @@index([userId])
  @@index([createdAt])
}

model ForumPost {
  id        String         @id @default(cuid())
  userId    String
  title     String
  content   String
  imageUrl  String         @default("")
  likeCount Int            @default(0)
  isSolved  Boolean        @default(false)
  isPinned  Boolean        @default(false)
  isLocked  Boolean        @default(false)
  category  String         @default("discussion")
  viewCount Int            @default(0)
  updatedAt DateTime       @default(now()) @updatedAt
  createdAt DateTime       @default(now())
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  comments  ForumComment[]
  likes     ForumPostLike[]

  @@index([userId])
  @@index([createdAt])
  @@index([category])
  @@index([category, createdAt])
  @@index([isSolved])
  @@index([isSolved, createdAt])
}

model ForumComment {
  id        String    @id @default(cuid())
  postId    String
  userId    String
  content   String
  imageUrl  String    @default("")
  likeCount Int       @default(0)
  updatedAt DateTime  @updatedAt
  createdAt DateTime  @default(now())
  post      ForumPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  likes     ForumCommentLike[]

  @@index([postId, createdAt])
  @@index([userId])
}

model Notification {
  id         String   @id @default(cuid())
  userId     String   // 接收通知的用户
  actorId    String   // 触发通知的用户
  type       String   // "forum_post_like" | "forum_comment_like" | "forum_comment_new" | "follow"
  targetType String   // "forum_post" | "forum_comment" | "user"
  targetId   String   // 关联对象 ID
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())
  user       User     @relation("notifications", fields: [userId], references: [id], onDelete: Cascade)
  actor      User     @relation("notificationTarget", fields: [actorId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
  @@index([actorId])
}

model ForumPostLike {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      ForumPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  @@unique([userId, postId])
  @@index([postId])
}

model ForumCommentLike {
  id        String      @id @default(cuid())
  userId    String
  commentId String
  createdAt DateTime    @default(now())
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment   ForumComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  @@unique([userId, commentId])
  @@index([commentId])
}

model CommentLike {
  id        String   @id @default(cuid())
  userId    String
  commentId String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  @@unique([userId, commentId])
  @@index([commentId])
}

/// 情感化消息管理 — 可在后台自定义各场景的提示文案和插图
model EmotionalMessage {
  id         String   @id @default(cuid())
  /// 唯一标识，如 "favorite_added", "checkin_success", "empty_search" 等
  key        String   @unique
  /// 场景分类: toast / empty / error / success
  category   String
  /// 正标题
  title      String   @default("")
  /// 副标题或描述
  subtitle   String   @default("")
  /// 插图 URL（可选，用于空状态/错误页等）
  imageUrl   String   @default("")
  /// 自定义 emoji 作为图标替代（当无插图时使用）
  emoji      String   @default("")
  /// 是否启用（禁用时走前端默认文案）
  enabled    Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([category])
  @@index([key])
}

/// 全局站点配置 — 键值对存储，用于后台可配置项
model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @default("")
  updatedAt DateTime @updatedAt
}

/// 成就定义 — 由管理员在后台创建
model Achievement {
  id              String   @id @default(cuid())
  name            String                // 成就名称
  description     String   @default("") // 成就描述
  icon            String   @default("") // 成就图标 URL
  characterImage  String   @default("") // 解锁卡片角色立绘 URL（透明底 PNG）
  category        String   @default("general") // 分类
  conditionType   String                // 条件类型：favorite_count / comment_count / play_count / checkin_streak / forum_post_count / register_days
  conditionTarget Int      @default(1)  // 目标值
  points          Int      @default(10) // 积分权重
  hidden          Boolean  @default(true) // 是否隐藏（全部默认隐藏）
  isActive        Boolean  @default(true) // 是否启用
  unlockCount     Int      @default(0)  // 解锁人数（定时统计更新）
  createdAt       DateTime @default(now())
  users           UserAchievement[]

  @@index([category])
  @@index([conditionType])
  @@index([isActive])
}

/// 用户成就解锁记录
model UserAchievement {
  id            String      @id @default(cuid())
  userId        String
  achievementId String
  unlockedAt    DateTime    @default(now())
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  @@unique([userId, achievementId])
  @@index([userId])
  @@index([achievementId])
}
