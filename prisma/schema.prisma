generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(cuid())
  serialId      Int            @unique @default(autoincrement())
  uid           String         @unique @default("")
  username      String         @unique
  email         String         @unique
  password      String
  avatar        String         @default("")
  avatarFrameId String?
  composedAvatarUrl String?    @default("")
  banner        String         @default("")
  bio           String         @default("")
  role          String         @default("USER")
  faveGameId    String?
  createdAt     DateTime       @default(now())
  avatarFrame   AvatarFrame?   @relation(fields: [avatarFrameId], references: [id], onDelete: SetNull)
  comments      Comment[]
  favorites     Favorite[]
  playStatuses  PlayStatus[]
  forumPosts    ForumPost[]
  forumComments ForumComment[]
  checkIns      CheckIn[]
  resetTokens   PasswordResetToken[]
  ratings       GameRating[]
  accounts      Account[]
  sessions      Session[]
  following     Follow[]        @relation("following")
  followers     Follow[]        @relation("followers")
  notifications Notification[]  @relation("notifications")
  sentNotifications Notification[] @relation("notificationTarget")
  collections      Collection[]
  publishedGames   Game[]

  @@index([role])
  @@index([serialId])
  @@index([avatarFrameId])
}

model AvatarFrame {
  id          String   @id @default(cuid())
  name        String
  description String   @default("")
  imageUrl    String
  isPublic    Boolean  @default(true)
  sort        Int      @default(0)
  createdAt   DateTime @default(now())
  users       User[]

  @@index([isPublic, sort])
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())
  follower    User     @relation("following", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("followers", fields: [followingId], references: [id], onDelete: Cascade)
  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Game {
  id            String       @id @default(cuid())
  serialId      Int          @unique @default(autoincrement())
  title         String
  originalWork  String       @default("")
  description   String       @default("")
  coverImage    String       @default("")
  screenshots   String       @default("[]")
  downloadLinks String       @default("[]")
  status        String       @default("完结")
  isNsfw        Boolean      @default(false)
  vndbId        String       @default("")
  viewCount     Int          @default(0)
  downloadCount Int          @default(0)
  favoriteCount Int          @default(0)
  platform      String       @default("")
  language      String       @default("")
  fileSize      String       @default("")
  isPublished   Boolean      @default(true)
  releaseDate   DateTime?
  gameDuration  String       @default("")
  studioName    String       @default("")
  englishName   String       @default("")
  aliases       String       @default("")
  publisherId   String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  publisher     User?        @relation(fields: [publisherId], references: [id], onDelete: SetNull)
  tags          GameTag[]
  comments      Comment[]
  favorites     Favorite[]
  playStatuses  PlayStatus[]
  reports       GameReport[]
  ratings       GameRating[]
  creators      GameCreator[]
  logs          GameLog[]

  @@index([isPublished, isNsfw, createdAt])
  @@index([isPublished, createdAt])
  @@index([title])
  @@index([vndbId])
  @@index([serialId])
}

model TagGroup {
  id          String   @id @default(cuid())
  name        String   @unique
  description String   @default("")
  color       String   @default("#7c8a9e")
  positions   String   @default("[]")  // JSON array of position keys
  isPreset    Boolean  @default(false)  // 系统内置组，不可删除
  tags        Tag[]
  createdAt   DateTime @default(now())
}

model Tag {
  id          String    @id @default(cuid())
  name        String    @unique
  description String    @default("")
  color       String    @default("#a78bfa")
  sortOrder   Int       @default(0)
  isVisible   Boolean   @default(true)
  groupId     String?
  createdAt   DateTime  @default(now())
  group       TagGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)
  games       GameTag[]
  @@index([groupId])
  @@index([sortOrder])
}

model GameTag {
  gameId String
  tagId  String
  game   Game   @relation(fields: [gameId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)
  @@id([gameId, tagId])
}

model Comment {
  id        String   @id @default(cuid())
  gameId    String
  userId    String
  content   String
  imageUrl  String   @default("")
  likeCount Int      @default(0)
  createdAt DateTime @default(now())
  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([gameId, createdAt])
  @@index([userId])
}

model Favorite {
  id           String @id @default(cuid())
  userId       String
  gameId       String
  collectionId String?
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  game         Game       @relation(fields: [gameId], references: [id], onDelete: Cascade)
  collection   Collection? @relation(fields: [collectionId], references: [id], onDelete: SetNull)
  @@unique([userId, gameId])
  @@index([collectionId])
}

model Collection {
  id          String     @id @default(cuid())
  userId      String
  name        String
  description String     @default("")
  isDefault   Boolean    @default(false)
  sortOrder   Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  favorites   Favorite[]

  @@unique([userId, name])
  @@index([userId])
}

model PlayStatus {
  id     String @id @default(cuid())
  userId String
  gameId String
  status String @default("想玩")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  game   Game   @relation(fields: [gameId], references: [id], onDelete: Cascade)
  @@unique([userId, gameId])
}

model GameReport {
  id        String   @id @default(cuid())
  gameId    String
  ip        String
  createdAt DateTime @default(now())
  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  @@unique([gameId, ip])
}

model Announcement {
  id        String   @id @default(cuid())
  title     String
  content   String
  imageUrl  String   @default("")
  link      String   @default("")
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
}

model Music {
  id        String   @id @default(cuid())
  title     String
  filename  String
  url       String   @default("")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model GameLog {
  id        String   @id @default(cuid())
  gameId    String
  content   String
  createdAt DateTime @default(now())
  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
}

model Creator {
  id          String        @id @default(cuid())
  vndbId      String        @default("")
  name        String
  nameJa      String        @default("")
  avatar      String        @default("")
  bio         String        @default("")
  gender      String        @default("")
  twitterUrl  String        @default("")
  wikipediaUrl String       @default("")
  createdAt   DateTime      @default(now())
  games       GameCreator[]

  @@index([vndbId])
  @@index([name])
}

model GameCreator {
  id        String  @id @default(cuid())
  gameId    String
  creatorId String
  role      String  // scenario / art / chardesign / music / director / songs
  game      Game    @relation(fields: [gameId], references: [id], onDelete: Cascade)
  creator   Creator @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  @@unique([gameId, creatorId, role])
}

model GameRating {
  id        String   @id @default(cuid())
  gameId    String
  userId    String
  score     Int      // 1-5
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([gameId, userId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CheckIn {
  id        String   @id @default(cuid())
  userId    String
  date      String   // YYYY-MM-DD
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([userId, date])
}

model ForumPost {
  id        String         @id @default(cuid())
  userId    String
  title     String
  content   String
  imageUrl  String         @default("")
  likeCount Int            @default(0)
  isSolved  Boolean        @default(false)
  createdAt DateTime       @default(now())
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  comments  ForumComment[]

  @@index([userId])
  @@index([createdAt])
}

model ForumComment {
  id        String    @id @default(cuid())
  postId    String
  userId    String
  content   String
  imageUrl  String    @default("")
  likeCount Int       @default(0)
  createdAt DateTime  @default(now())
  post      ForumPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([postId, createdAt])
  @@index([userId])
}

model Notification {
  id         String   @id @default(cuid())
  userId     String   // 接收通知的用户
  actorId    String   // 触发通知的用户
  type       String   // "forum_post_like" | "forum_comment_like" | "forum_comment_new" | "follow"
  targetType String   // "forum_post" | "forum_comment" | "user"
  targetId   String   // 关联对象 ID
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())
  user       User     @relation("notifications", fields: [userId], references: [id], onDelete: Cascade)
  actor      User     @relation("notificationTarget", fields: [actorId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
  @@index([actorId])
}

/// 情感化消息管理 — 可在后台自定义各场景的提示文案和插图
model EmotionalMessage {
  id         String   @id @default(cuid())
  /// 唯一标识，如 "favorite_added", "checkin_success", "empty_search" 等
  key        String   @unique
  /// 场景分类: toast / empty / error / success
  category   String
  /// 正标题
  title      String   @default("")
  /// 副标题或描述
  subtitle   String   @default("")
  /// 插图 URL（可选，用于空状态/错误页等）
  imageUrl   String   @default("")
  /// 自定义 emoji 作为图标替代（当无插图时使用）
  emoji      String   @default("")
  /// 是否启用（禁用时走前端默认文案）
  enabled    Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([category])
  @@index([key])
}

/// 全局站点配置 — 键值对存储，用于后台可配置项
model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @default("")
  updatedAt DateTime @updatedAt
}